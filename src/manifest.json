{
  "manifest_version": 2,
  "name": "Sorted",
  "version": "2.2",

  "description": "Makes managing bookmarks easier by sorting them into folders based on keywords provided by the user.",
  "homepage_url": "https://ramitmittal.github.io/sorted",
  "icons": {
    "48": "icons/icon-48.png",
    "32": "icons/icon-32.png"
  },

  "permissions": [
    "bookmarks"
  ],

  "browser_action": {
    "browser_style": true,
    "default_icon": "icons/icon-48.png",
    "default_title": "Sorted",
    "default_popup": "popup/popup.html"
  }

}
