{
  "name": "sorted",
  "version": "2.3.3",
  "description": "A Mozilla Firefox extension.",
  "repository": {
    "type": "git",
    "url": "git+https://ramitm@bitbucket.org/ramitm/sorted.git"
  },
  "author": "Ramit Mittal",
  "license": "GPL-3.0-or-later",
  "scripts": {
    "build": "rm -rf dist/ && parcel build src/popup/popup.html --public-url '.' --out-dir dist/popup && cp -r src/manifest.json src/icons dist/",
    "prestart": "npm run build",
    "start": "web-ext run -s dist/",
    "pack": "node scripts/validate && web-ext build -s dist/ -a artifacts/"
  },
  "bugs": {
    "url": "https://bitbucket.org/ramitm/sorted/issues"
  },
  "homepage": "https://bitbucket.org/ramitm/sorted",
  "devDependencies": {
    "@babel/cli": "^7.7.4",
    "@babel/core": "^7.7.4",
    "@babel/plugin-transform-runtime": "^7.7.4",
    "@babel/preset-env": "^7.7.4",
    "cssnano": "^4.1.10",
    "eslint": "^5.16.0",
    "eslint-config-airbnb-base": "^13.2.0",
    "eslint-plugin-import": "^2.18.2",
    "parcel-bundler": "^1.12.4",
    "sass": "^1.23.7",
    "web-ext": "^3.2.1"
  },
  "dependencies": {
    "@babel/polyfill": "^7.7.0",
    "@babel/runtime": "^7.7.4",
    "bulma": "^0.7.5"
  }
}
